}

### WIDGETS
flowcontainer = {
	name = "widget_je_meiji_restoration_daimyos_list"
	ignoreinvisible = yes

	flowcontainer = {
		direction = vertical

		section_header_button = {
			blockoverride "layout" {
				size = { 520 38 }
			}
			blockoverride "left_text" {
				text = "DAIMYOS_LIST_HEADER"
			}
			blockoverride "onclick" {
				onclick = "[GetVariableSystem.Toggle('daimyos_list_toggle')]"
			}
			blockoverride "onclick_showmore" {
				visible = "[Not(GetVariableSystem.Exists('daimyos_list_toggle'))]"
			}
			blockoverride "onclick_showless" {
				visible = "[GetVariableSystem.Exists('daimyos_list_toggle')]"
			}
		}

		fixedgridbox = {
			visible = "[GetVariableSystem.Exists('daimyos_list_toggle')]"
			datamodel = "[JournalEntry.GetCountry.MakeScope.GetList('daimyos_list')]"
			addcolumn = 500
			addrow = 110

			background = {
				texture = "gfx/interface/tooltip/tooltip_title_bg.dds"
				color = { 0.69 0.47 0.33 1 }
				alpha = 0.4

				modify_texture = {
					using = texture_velvet
				}
			}

			item = {
				ep2_meiji_restoration_daimyos_widget = {}
			}
		}
		expand = {}
	}
}

flowcontainer = {
	name = "widget_je_meiji_restoration_emperor"
	ignoreinvisible = yes

	### RULER
	flowcontainer = {
		direction = vertical

		ep2_meiji_restoration_character_with_background_japanese_emperor = {
			state = {
				name = update
				trigger_on_create = yes
				on_finish = "[GetScriptedGui('je_meiji_restoration_japanese_emperor_sgui').Execute(GuiScope.SetRoot(JournalEntry.GetCountry.MakeScope).End)]"
			}

			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			minimumsize = { 520 280 }

			blockoverride "character_layout" {
				position = { 0 0 }
				size = { 80% 100% }
			}
			blockoverride "character_portrait_size" {
				size = { 100% 100% }
			}

			# ruler stats
			flowcontainer = {
				parentanchor = right|top
				position = { -8 5 }
				direction = vertical
				spacing = 5

				background = {
					using = dark_area
					alpha = 0.75

					modify_texture = {
						texture = "gfx/interface/masks/fade_horizontal_left_full.dds"
						blend_mode = alphamultiply
					}
				}

				### ROLE
				ruler_stats_entry = {
					tooltip = "CHARACTER_PRIMARY_ROLE_TOOLTIP"

					blockoverride "ruler_icon" {
						widget = {
							size = { 35 35 }
							icon = {
								size = { 100% 100% }
								texture = "gfx/interface/icons/faction_icons/faction_japan_imperial_house.dds"
							}
						}
					}
					blockoverride "label" {
						text = "[Character.GetPrimaryRoleTitle]"
					}
					blockoverride "text" {
						text = "[Character.GetFirstName]"
					}
				}
				## INTEREST GROUP
				ruler_stats_entry = {
					datacontext = "[Character.GetInterestGroup]"

					blockoverride "ruler_icon" {
						character_ig_button = {
							size = { 35 35 }
							blockoverride "in_government_icon" {}
						}
					}

					tooltipwidget = {
						FancyTooltip_IG = {}
					}

					blockoverride "label" {
						text = "INTEREST_GROUP"
					}
					blockoverride "text" {
						raw_text = "#v [Character.GetInterestGroup.GetNameNoFormatting]#!"
					}
				}

				### IDEOLOGY
				ruler_stats_entry = {
					datacontext = "[Character.GetIdeology]"

					tooltipwidget = {
						FancyTooltip_Ideology = {}
					}
					blockoverride "icon_texture" {
						texture = "[Ideology.GetTexture]"
					}
					blockoverride "label" {
						text = "IDEOLOGY_CONCEPT"
					}
					blockoverride "text" {
						text = "CHARACTER_IDEOLOGY"
					}
				}
				#POPULARITY
				ruler_stats_entry = {
					tooltip = "PROMINENCE_BREAKDOWN"

					blockoverride "icon_texture" {
						texture = "gfx/interface/icons/generic_icons/prominence.dds"
					}
					blockoverride "label" {
						text = "PROMINENCE"
					}
					blockoverride "text" {
						text = "CHARACTER_PROMINENCE"
					}
				}

				### TRAITS
				character_traits_no_label = {
					parentanchor = right
				}
			}
		}
	}
}
