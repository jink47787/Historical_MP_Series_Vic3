		ep2_meiji_restoration_faction_button_base = {
			visible = "[GetScriptedGui('je_meiji_restoration_get_faction_sgui').IsValid( GuiScope.SetRoot( State.MakeScope ).AddScope( 'frame', MakeScopeValue( '(CFixedPoint)3') ).End )]"
			parentanchor = center

			blockoverride "size" {
				size = { 45 45 }
			}
			blockoverride "icon_size" {
				size = { 100% 100% }
			}
			blockoverride "icon" {
				texture = "gfx/interface/icons/faction_icons/faction_japan_ii.dds"
			}
		}

		ep2_meiji_restoration_faction_button_base = {
			visible = "[GetScriptedGui('je_meiji_restoration_get_faction_sgui').IsValid( GuiScope.SetRoot( State.MakeScope ).AddScope( 'frame', MakeScopeValue( '(CFixedPoint)4') ).End )]"
			parentanchor = center

			blockoverride "size" {
				size = { 45 45 }
			}
			blockoverride "icon_size" {
				size = { 100% 100% }
			}
			blockoverride "icon" {
				texture = "gfx/interface/icons/faction_icons/faction_japan_maeda.dds"
			}
		}

		ep2_meiji_restoration_faction_button_base = {
			visible = "[GetScriptedGui('je_meiji_restoration_get_faction_sgui').IsValid( GuiScope.SetRoot( State.MakeScope ).AddScope( 'frame', MakeScopeValue( '(CFixedPoint)5') ).End )]"
			parentanchor = center

