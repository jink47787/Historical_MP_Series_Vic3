# COPY-PASTED FOR NOW
@panel_width_minus_10 = 530			# used to be 450
@panel_width = 540  				# used to be 460
@panel_width_half = 270				# used to be 230
@panel_width_plus_10 = 550  		# used to be 470
@panel_width_plus_14 = 554			# used to be 474
@panel_width_plus_14_half = 277		# used to be 237
@panel_width_plus_20 = 560			# used to be 480
@panel_width_plus_30 = 570			# used to be 490
@panel_width_plus_70 = 610			# used to be 530

types naval_battle_panel_types
{
	type naval_battle_panel = default_block_window_two_lines {
		name = "naval_battle_panel"
		datacontext = "[NavalBattlePanel.GetBattle]"

		blockoverride "window_header_name"
		{
			text = "[LabelingHelper.CapitalizeOnlyFirst(NavalBattle.GetName)]"
		}
		blockoverride "window_header_name_line_two"
		{
			text = "NAVAL_BATTLE_SUBTITLE"
		}

		blockoverride "goto_visibility" {}

		blockoverride "goto_properties" {
			onclick = "[NavalBattle.ZoomToMapMarkerPosition]"
			tooltip = "ZOOM_TO_NAVAL_BATTLE"
			enabled = "[Not( NavalBattle.IsZoomingToMapMarkerPosition )]"
		}

		blockoverride "goto_button" {
			button_icon_goto = {
				datacontext = "[NavalBattle.GetProvince]"
				size = { 30 30 }
				onclick = "[InformationPanelBar.OpenSeaRegionPanel(Province.Self)]"
				tooltip = "GO_TO_BUTTON_SEA_REGION"
				input_action = "go_to_details"
			}
		}

		blockoverride "animation_state_block" {
			state = {
				name = _show
				using = viewport_sound_parameter_open
				using = naval_battle_panel_open
			}

			state = {
				name = _hide
				using = viewport_sound_parameter_close
			}
		}

		blockoverride "fixed_top"
		{
			tab_buttons = {
				# Overview
				blockoverride "first_button" {
					text = "OVERVIEW"
				}
				blockoverride "first_button_tooltip" {
					tooltip = "OVERVIEW"
				}
				blockoverride "first_button_click" {
					onclick = "[InformationPanel.SelectTab('default')]"
				}
				blockoverride "first_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('default')]"
				}
				blockoverride "first_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('default') )]"
				}
				blockoverride "first_button_selected" {
					text = "OVERVIEW"
				}

				# Battle Log
				blockoverride "second_button" {
					text = "BATTLE_LOG"
				}
				blockoverride "second_button_tooltip" {
					tooltip = "BATTLE_LOG"
				}
				blockoverride "second_button_click" {
					onclick = "[InformationPanel.SelectTab('battle_log')]"
				}
				blockoverride "second_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('battle_log')]"
				}
				blockoverride "second_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('battle_log') )]"
				}
				blockoverride "second_button_selected" {
					text = "BATTLE_LOG"
				}
			}

			flowcontainer = {
				visible = "[InformationPanel.IsTabSelected('battle_log')]"
				direction = vertical
				spacing = 5
				margin_top = 5

				state = {
					name = _show
					using = naval_battle_combat_log_open
				}

				state = {
					name = _hide
					using = naval_battle_combat_log_close
				}

				widget = {
					size = { @panel_width 120 }

					background = {
						texture = "gfx/interface/illustrations/top_illus/top_illu_navy.dds"
						using = top_illu_properties
					}

					background = {
						using = entry_bg
					}

					battle_results = {}

					state = {
						name = _show
						using = naval_battle_combat_log_open
					}

					state = {
						name = _hide
						using = naval_battle_combat_log_close
					}

					attacker_progress = {
						visible = "[NavalBattle.IsActive]"
						datacontext = "[NavalBattle.GetAttackerSide]"
						parentanchor = bottom
					}

					defender_progress = {
						visible = "[NavalBattle.IsActive]"
						datacontext = "[NavalBattle.GetDefenderSide]"
						parentanchor = right|bottom
					}
				}

				flowcontainer = {
					margin_bottom = 5
					parentanchor = hcenter

					#ALL EVENTS
					filter_button_battle_log = {
						visible = "[Not(NavalBattle.IsLogFilterAll)]"
						blockoverride "text" {
							text = "NAVAL_BATTLE_SHOW_ALL_EVENTS"
						}

						blockoverride "onclick" {
							onclick = "[NavalBattle.SetLogFilterAll]"
						}
					}

					filter_background_selected_battle_log = {
						visible = "[NavalBattle.IsLogFilterAll]"

						blockoverride "text" {
							text = "NAVAL_BATTLE_SHOW_ALL_EVENTS"
						}
					}

					#HIGH PRIO EVENTS
					filter_button_battle_log = {
						visible = "[Not(NavalBattle.IsLogFilterMajor)]"

						blockoverride "text" {
							text = "NAVAL_BATTLE_MAJOR_EVENTS"
						}

						blockoverride "onclick" {
							onclick = "[NavalBattle.SetLogFilterMajor]"
						}
					}

					filter_background_selected_battle_log = {
						visible = "[NavalBattle.IsLogFilterMajor]"

						blockoverride "text" {
							text = "NAVAL_BATTLE_MAJOR_EVENTS"
						}
					}

					#STANDARD PRIO EVENTS
					filter_button_battle_log = {
						visible = "[Not(NavalBattle.IsLogFilterStandard)]"

						blockoverride "text" {
							text = "NAVAL_BATTLE_STANDARD_EVENTS"
						}

						blockoverride "onclick" {
							onclick = "[NavalBattle.SetLogFilterStandard]"
						}
					}

					filter_background_selected_battle_log = {
						visible = "[NavalBattle.IsLogFilterStandard]"

						blockoverride "text" {
							text = "NAVAL_BATTLE_STANDARD_EVENTS"
						}
					}
				}
			}
		}

		blockoverride "scrollarea_content"
		{
			container = {
				parentanchor = hcenter

				container = {
					visible = "[InformationPanel.IsTabSelected('default')]"
					using = default_content_fade

					flowcontainer = {
            			parentanchor = center
						direction = vertical
						spacing = 5

						widget = {
							size = { @panel_width_plus_14 360 }
							parentanchor = hcenter

							background = {
								visible = "[NavalBattle.HasEnded]"
								texture = "gfx/interface/navy/bg_illu_naval_combat.dds"
								alpha = 0.7
								using = top_illu_properties
								fittype = centercrop
							}

							background = {
								using = entry_bg_simple
							}


							flowcontainer = {
								parentanchor = hcenter

								ship_viewer = {
									visible = "[Not(NavalBattle.HasEnded)]"
									datacontext = "[NavalBattlePanel.GetAttackerShipViewer]"

									name = "attacker_ship_viewer_widget"
									size = { @panel_width_plus_14_half 360 }
								}

								vertical_divider_navy_frame = {
								}


								ship_viewer = {
									visible = "[Not(NavalBattle.HasEnded)]"
									datacontext = "[NavalBattlePanel.GetDefenderShipViewer]"

									name = "defender_ship_viewer_widget"
									size = { @panel_width_plus_14_half 360 }
								}
							}


							icon = {
								size = { 100% 100% }
								texture = "gfx/interface/navy/navy_bg_frame.dds"
								spriteType = Corneredtiled

								spriteborder_left = 200
								spriteborder_right = 60
								spriteborder_top = 170
								spriteborder_bottom = 180

								texture_density = 2
							}

							flowcontainer = {
								visible = "[And(NavalBattlePanel.HasHighlightedBattleEvent, Not(NavalBattle.HasEnded))]"
								position = { 0 15 }
								parentanchor = hcenter
								direction = vertical
								spacing = 10
								min_width = 500

								background = {
									using = entry_bg
									margin = { 15 6 }
								}

								textbox = {
									align = hcenter
									parentanchor = hcenter
									autoresize = yes
									raw_text = "[NavalBattlePanel.GetHighlightedBattleEventLogEntry.GetDescription]"
								}
							}

							battle_results = {
								position = { 0 50 }
							}

							#attacker
							diorama_stats = {
								position = { 12 54 }
								visible = "[NavalBattlePanel.HasHighlightedBattleEvent]"
								datacontext = "[NavalBattle.GetAttackerSide]"
								datacontext = "[NavalBattlePanel.GetHighlightedBattleEventLogEntry]"
								datacontext = "[NavalBattlePanel.GetHighlightedBattleEventLogEntry.GetAttackerSideCombatShip]"
							}

            				attacker_admiral = {
            					parentanchor = vcenter
            				}

							#defender
							diorama_stats = {
								position = { -12 54 }
								visible = "[NavalBattlePanel.HasHighlightedBattleEvent]"
								datacontext = "[NavalBattle.GetDefenderSide]"
								datacontext = "[NavalBattlePanel.GetHighlightedBattleEventLogEntry]"
								datacontext = "[NavalBattlePanel.GetHighlightedBattleEventLogEntry.GetDefenderSideCombatShip]"
								parentanchor = right
							}

            				defender_admiral = {
            					parentanchor = right|vcenter
            				}
						}

						flowcontainer = {
							parentanchor = hcenter
							direction = vertical
							spacing = 5
							margin_top = 5
							margin_bottom = 5

							background = {
								using = entry_bg
							}

							textbox = {
								size = { @panel_width_minus_10 25 }
								align = hcenter
								text = "NAVAL_BATTLE_CONDITION"
							}

							textbox = {
								size = { @panel_width_minus_10 25 }
								align = hcenter
								text = "NAVAL_BATTLE_START_DATE"
							}
						}

						flowcontainer = {
            				parentanchor = hcenter

							naval_battle_side_content_attacker = {
							}

							vertical_divider_stronger_full = {
								parentanchor = hcenter
							}

							naval_battle_side_content_defender = {
								parentanchor = right
							}
						}
					}
				}

				flowcontainer = {
					direction = vertical
					visible = "[InformationPanel.IsTabSelected('battle_log')]"
					datamodel = "[NavalBattle.GetLogEntries]"
					using = default_content_fade
					spacing = 5

					item = {
						flowcontainer = {
							direction = vertical

							battle_log_entry = {
								visible = "[BattleLogEntry.IsAttack]"
							}

							battle_log_entry_withdrew = {
								visible = "[BattleLogEntry.IsWithdraw]"
							}

							battle_log_entry_condition = {
								visible = "[BattleLogEntry.HasBattleCondition]"
							}
						}
					}
				}
			}
		}

		blockoverride "fixed_bottom"
		{
			flowcontainer = {
				visible = "[And(InformationPanel.IsTabSelected('battle_log'), GreaterThan_int32(NavalBattle.GetNumLogPages, '(int32)1'))]"
				direction = vertical

				divider_clean = {
					size = { @panel_width_plus_14 4 }
				}

				flowcontainer = {
					spacing = 20
					margin_top = 30
					using = default_list_position

					button_select_arrow = {
						size = { 25 25 }
						mirror = horizontal
						parentanchor = vcenter
						using = decrease_button_sound
						using = tooltip_above
						tooltip = "PREVIOUS_PAGE"
						onclick = "[NavalBattle.PrevLogPage]"
					}

					text_single = {
						text = "NAVAL_BATTLE_LOG_CURRENT_PAGE"
						parentanchor = vcenter
						align = nobaseline
					}

					button_select_arrow = {
						size = { 25 25 }
						parentanchor = vcenter
						using = increase_button_sound
						using = tooltip_above
						tooltip = "NEXT_PAGE"
						onclick = "[NavalBattle.NextLogPage]"
					}
				}
			}
		}
	}

	type battle_log_entry = widget {
		size = { @panel_width 120 }

		background = {
			using = entry_bg_simple
		}

		vbox = {
			margin = { 0 10 }
			layoutpolicy_vertical = expanding
			spacing = 5

			textbox = {
				margin_left = 10
				size = { @panel_width 25 }
				text = "[BattleLogEntry.GetDescription]"
				align = nobaseline
				using = elide_fontsize_min
			}

			hbox = {
				datacontext = "[NavalBattle.GetAttacker]"
				layoutpolicy_horizontal = expanding
				margin_top = 5
				margin_left = 10
				margin_right = 10

				widget = {
					size = { 170 60 }

					flowcontainer = {
						spacing = 5

						### ATTACKER SIDE - Is Actor
						attacker_battle_log_actor = {}

						### ATTACKER SIDE - Is Target
						attacker_battle_log_target = {}
					}
				}

				expand = {}

				vbox = {
					spacing = 5

					### ATTACKER SIDE
					icon = {
						visible = "[Not(BattleLogEntry.IsActorDefender)]"
						size = { 32 32 }
						texture = "gfx/interface/icons/generic_icons/win_war_against.dds"
					}

					### DEFENDER SIDE
					icon = {
						visible = "[BattleLogEntry.IsActorDefender]"
						size = { 32 32 }
						texture = "gfx/interface/icons/generic_icons/win_war_against.dds"
						mirror = horizontal
					}

					hbox = {
						spacing = 5

						textbox = {
							visible = "[BattleLogEntry.IsCritical]"
							margin = { 5 0 }
							autoresize = yes
							align = nobaseline
							raw_text = "@ship_critical_hit_damage! #v [BattleLogEntry.GetHullDamage] #!"
						}

						textbox = {
							visible = "[Not( BattleLogEntry.IsCritical)]"
							margin = { 5 0 }
							autoresize = yes
							align = nobaseline
							raw_text = "@hull_attack_damage! #v [BattleLogEntry.GetHullDamage] #!"
						}

						textbox = {
							margin = { 5 0 }
							autoresize = yes
							align = nobaseline
							raw_text = "@crew_attack_damage! #v [BattleLogEntry.GetCrewDamage] #!"
						}

					}
				}

				expand = {}

				widget = {
					size = { 170 60 }

					flowcontainer = {
						spacing = 5
						parentanchor = right


						### DEFENDER SIDE - Is Actor
						defender_battle_log_actor = {}

						### DEFENDER SIDE - Is Target
						defender_battle_log_target = {}
					}
				}
			}
		}
	}

	type battle_log_entry_withdrew = widget {
		size = { @panel_width 120 }

		background = {
			using = entry_bg_simple
		}

		vbox = {
			margin = { 0 10 }
			layoutpolicy_vertical = expanding
			spacing = 5

			textbox = {
				margin_left = 10
				size = { @panel_width 25 }
				text = "[BattleLogEntry.GetDescription]"
				using = elide_fontsize_min
			}

			hbox = {
				datacontext = "[NavalBattle.GetAttacker]"
				layoutpolicy_horizontal = expanding
				margin_top = 5
				margin_left = 10
				margin_right = 10

				widget = {
					size = { 170 60 }

					flowcontainer = {
						visible = "[Not(BattleLogEntry.IsActorDefender)]"
						spacing = 5

						### ATTACKER SIDE - Is Actor
						attacker_battle_log_actor = {}
					}
				}

				expand = {}

				vbox = {

					### ATTACKER SIDE
					icon = {
						visible = "[Not(BattleLogEntry.IsActorDefender)]"
						size = { 32 32 }
						texture = "gfx/interface/icons/generic_icons/turns_into.dds"
						mirror = horizontal
					}

					### DEFENDER SIDE
					icon = {
						visible = "[BattleLogEntry.IsActorDefender]"
						size = { 32 32 }
						texture = "gfx/interface/icons/generic_icons/turns_into.dds"
					}

					icon = {
						size = { 30 30 }
						texture = "gfx/interface/icons/military_icons/ships_fled.dds"
					}
				}

				expand = {}

				widget = {
					size = { 170 60 }

					flowcontainer = {
						visible = "[BattleLogEntry.IsActorDefender]"
						spacing = 5
						parentanchor = right


						### DEFENDER SIDE - Is Actor
						defender_battle_log_actor = {}
					}
				}
			}
		}
	}

	type battle_log_entry_condition = widget {
		size = { @panel_width 120 }

		background = {
			using = entry_bg_simple
		}

		background = {
			texture = "gfx/interface/illustrations/top_illus/top_illu_navy_2.dds"
			using = top_illu_properties
		}

		vbox = {
			margin = { 0 10 }
			layoutpolicy_vertical = expanding
			spacing = 5

			textbox = {
				margin_left = 10
				size = { @panel_width 25 }
				text = "[BattleLogEntry.GetDescription]"
				using = elide_fontsize_min
			}

			hbox = {
				datacontext = "[NavalBattle.GetAttacker]"
				layoutpolicy_horizontal = expanding
				margin_top = 5
				margin_left = 10
				margin_right = 10

				widget = {
					size = { 170 60 }

					tiny_flag_no_interact = {
						datacontext = "[NavalBattle.GetAttacker]"
						parentanchor = vcenter
						blockoverride "is_player_glow_size" {
							size = { 270% 270% }
						}
					}
				}

				expand = {}

				hbox = {

					textbox = {
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline
						raw_text = "@hull_attack_damage! #v [BattleLogEntry.GetHullDamage] #!"
					}

					textbox = {
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline
						raw_text = "@crew_attack_damage! #v [BattleLogEntry.GetCrewDamage] #!"
					}
				}

				expand = {}

				widget = {
					size = { 170 60 }

					tiny_flag_no_interact = {
						parentanchor = right|vcenter
						datacontext = "[NavalBattle.GetDefender]"
						blockoverride "is_player_glow_size" {
							size = { 270% 270% }
						}
					}
				}
			}
		}
	}

	type attacker_admiral = widget {
		size = { @panel_width_half 360 }
		datacontext = "[NavalBattle.GetAttackerSide]"
		datacontext = "[NavalBattleSide.GetCommander]"

		character_portrait_base = {
			parentanchor = vcenter
			position = { 0 30 }
			size = { 120 220 }

			blockoverride "portrait_size" {
				block "character_portrait_size" {
					size = { 120 220 }
				}
			}

			blockoverride "portrait_texture" {
				portrait_texture = "[Character.GetAnimatedPortrait('environment_front_generals_left', 'camera_event_left', 'commander_vs_left', GetPortraitRenderSize(PdxGuiWidget.Self))]"
			}

			blockoverride "portrait_icons" {}
			blockoverride "highlight" {}
		}

		attacker_progress = {
			parentanchor = bottom
		}
	}

	type attacker_progress = flowcontainer {
		direction = vertical
		margin_left = 15
		spacing = 10
		margin_bottom = 20

		flowcontainer = {

			dynamicgridbox = {
				datamodel = "[NavalBattleSide.GetCommander.AccessTraits]"
				datamodel_wrap = 6
				flipdirection = yes

				item = {

					icon = {
						size = { 21 30 }
						texture = "[CharacterTrait.GetTexture]"
						using = tooltip_ne
						tooltipwidget = {
							FancyTooltip_CharacterTrait = {}
						}
					}
				}
			}
		}

		widget = {
			size = { 215 45 }

			flowcontainer = {
				direction = vertical
				datacontext = "[NavalBattle.GetAttackerSide]"
				parentanchor = right|vcenter

				background = {
					using = simple_frame
					margin = { 3 3 }
				}

				bar_horizontal_with_background = {
					size = { 148 25 }

					block "first_bar_tooltip" {
						tooltip = "NAVAL_BATTLE_SIDE_AVERAGE_HULL_TOOLTIP"
					}

					blockoverride "frame_texture_density" {
						texture_density = 4
					}

					blockoverride "values" {
						min = 0
						max = 1
						value = "[NavalBattleSide.GetActiveHullShare]"
					}

					textbox = {
						parentanchor = vcenter|left
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline

						block "first_bar_text" {
							raw_text = "@ship_hp! #b [NavalBattleSide.GetActiveHullShare|0%]#!"
						}
					}

					blockoverride "color" {
						using = color_green_approval
					}
				}

				bar_horizontal_with_background = {
					size = { 148 18 }

					block "first_bar_tooltip" {
						tooltip = "NAVAL_BATTLE_SIDE_AVERAGE_CREW_TOOLTIP"
					}

					blockoverride "frame_texture_density" {
						texture_density = 4
					}

					blockoverride "values" {
						min = 0
						max = 1
						value = "[NavalBattleSide.GetActiveCrewShare]"
					}

					textbox = {
						parentanchor = vcenter|left
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline
						using = fontsize_small

						block "second_bar_text" {
							raw_text = "@crew! #b [NavalBattleSide.GetTotalCrew|D]#! / [NavalBattleSide.GetMaxCrew|D]"
						}
					}

					blockoverride "color" {
						using = color_blue_negative
					}
				}
			}

			flag = {
				parentanchor = vcenter
				datacontext = "[NavalBattle.GetAttacker]"
			}
		}
	}

	type defender_admiral = widget {
		size = { @panel_width_half 360 }
		datacontext = "[NavalBattle.GetDefenderSide]"
		datacontext = "[NavalBattleSide.GetCommander]"

		character_portrait_base = {
			visible = "[Character.IsValid]"
			parentanchor = right|vcenter
			position = { 0 30 }
			size = { 120 220 }

			blockoverride "portrait_size" {
				block "character_portrait_size" {
					size = { 120 220 }
				}
			}

			blockoverride "portrait_texture" {
				portrait_texture = "[Character.GetAnimatedPortrait('environment_front_generals_right', 'camera_event_right', 'commander_vs_right', GetPortraitRenderSize(PdxGuiWidget.Self))]"
			}

			blockoverride "portrait_icons" {}
			blockoverride "highlight" {}
		}

		defender_progress = {
			parentanchor = right|bottom
		}
	}

	type defender_progress = flowcontainer {
		direction = vertical
		margin_right = 15
		spacing = 10
		margin_bottom = 20

		flowcontainer = {
			margin_right = 15
			parentanchor = right

			dynamicgridbox = {
				layoutanchor = topright
				datamodel = "[NavalBattleSide.GetCommander.AccessTraits]"
				datamodel_wrap = 6
				flipdirection = yes

				item = {
					icon = {
						size = { 21 30 }
						texture = "[CharacterTrait.GetTexture]"
						using = tooltip_above
						tooltipwidget = {
							FancyTooltip_CharacterTrait = {}
						}
					}
				}
			}
		}

		widget = {
			size = { 216 45 }

			flowcontainer = {
				direction = vertical
				parentanchor = vcenter

				background = {
					using = simple_frame
					margin = { 3 3 }
				}

				bar_horizontal_with_background = {
					size = { 148 25 }

					block "first_bar_tooltip" {
						tooltip = "NAVAL_BATTLE_SIDE_AVERAGE_HULL_TOOLTIP"
					}

					blockoverride "frame_texture_density" {
						texture_density = 4
					}

					blockoverride "values" {
						invertprogress = yes
						min = 0
						max = 1
						value = "[NavalBattleSide.GetActiveHullShare]"
					}

					textbox = {
						parentanchor = vcenter|right
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline

						block "first_bar_text" {
							raw_text = "@ship_hp! #b [NavalBattleSide.GetActiveHullShare|0%]#!"
						}
					}

					blockoverride "marker_widgetanchor" {
						visible = "[NotZero_CFixedPoint(NavalBattleSide.GetActiveHullShare)]"
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "color" {
						using = color_green_approval
					}
				}

				bar_horizontal_with_background = {
					size = { 148 18 }

					block "first_bar_tooltip" {
						tooltip = "NAVAL_BATTLE_SIDE_AVERAGE_CREW_TOOLTIP"
					}

					blockoverride "frame_texture_density" {
						texture_density = 4
					}

					blockoverride "values" {
						invertprogress = yes
						min = 0
						max = 1
						value = "[NavalBattleSide.GetActiveCrewShare]"
					}

					textbox = {
						parentanchor = vcenter|right
						margin = { 5 0 }
						autoresize = yes
						align = nobaseline
						using = fontsize_small

						block "second_bar_text" {
							raw_text = "@crew! #b [NavalBattleSide.GetTotalCrew|D]#! / [NavalBattleSide.GetMaxCrew|D]"
						}
					}

					blockoverride "marker_widgetanchor" {
						visible = "[NotZero_CFixedPoint(NavalBattleSide.GetActiveCrewShare)]"
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "color" {
						using = color_blue_negative
					}
				}
			}

			flag = {
				parentanchor = right|vcenter
				datacontext = "[NavalBattle.GetDefender]"
			}
		}
	}

	type diorama_stats = flowcontainer {
		visible = "[NavalBattle.IsActive]"
		direction = vertical
		spacing = 10

		block "background" {
			background = {
				margin_top = 5
				margin_bottom = 5
				using = dark_area
				alpha = 0.55
			}
		}

		### ATTACKER
		ship_type_silhouette = {
			visible = "[NavalBattleSide.IsAttacker]"
			datacontext = "[CombatShip.GetShip.GetType]"
			size = { 100% 20 }
			parentanchor = hcenter
		}

		### DEFENDER
		ship_type_silhouette = {
			visible = "[NavalBattleSide.IsDefender]"
			datacontext = "[CombatShip.GetShip.GetType]"
			size = { 100% 20 }
			parentanchor = hcenter

			blockoverride "direction" {
				mirror = horizontal
			}
		}

		flowcontainer = {
			direction = vertical

			textbox = {
				visible = "[BattleLogEntry.IsActor(CombatShip.Self)]"
				margin = { 5 0 }
				autoresize = yes
				align = nobaseline
				raw_text = "@ship_hp! #v [CombatShip.GetShip.GetHitPoints|0]#!"
			}

			textbox = {
				visible = "[BattleLogEntry.IsActor(CombatShip.Self)]"
				margin = { 5 0 }
				autoresize = yes
				align = nobaseline
				raw_text = "@crew! #v [CombatShip.GetShip.GetTotalCrew|0]#!"
			}

			textbox = {
				visible = "[BattleLogEntry.IsTarget(CombatShip.Self)]"
				margin = { 5 0 }
				autoresize = yes
				align = nobaseline
				parentanchor = right
				raw_text = "@ship_hp! #v [CombatShip.GetShip.GetHitPoints|0]#! (#r -[BattleLogEntry.GetHullDamage|0]#!)"
			}

			textbox = {
				visible = "[BattleLogEntry.IsTarget(CombatShip.Self)]"
				margin = { 5 0 }
				autoresize = yes
				align = nobaseline
				parentanchor = right
				raw_text = "@crew! #v [CombatShip.GetShip.GetTotalCrew|0]#! (#r -[BattleLogEntry.GetCrewDamage|0]#!)"
			}
		}
	}

	type fleets_grid_item = widget {
		size = { 90 30 }
		using = tooltip_se

		block "backgrounds" {
			background = {
				using = entry_bg_simple
				margin_left = -10

				block "background_alpha" {
					alpha = 0.5
				}
			}

