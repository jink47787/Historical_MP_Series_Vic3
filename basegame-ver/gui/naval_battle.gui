	type naval_battle_side_ships_list = flowcontainer {
		minimumsize = { @panel_width_plus_14_half -1 }
		maximumsize = { @panel_width_plus_14_half -1 }
		direction = vertical
		datamodel = "[NavalBattleSide.GetShipTemplateGroups]"
		parentanchor = hcenter

		item = {
			flowcontainer = {
				datacontext = "[NavalBattleShipTemplateGroup.GetTemplate]"
				minimumsize = { @panel_width_half -1 }
				maximumsize = { @panel_width_half -1 }
				direction = vertical
				margin_top = 10

				using = entry_bg_fancy

				section_header_button = {
					parentanchor = hcenter
					minimumsize = { @panel_width_half -1 }
					maximumsize = { @panel_width_half -1 }
					tooltip = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_NUM_TOOLTIP"

					blockoverride "onclick" {
						onclick = "[GetVariableSystem.Toggle(Concatenate('naval_battle_ship_template_group_', NavalBattleShipTemplateGroup.GetIDString))]"
					}

					blockoverride "onclick_showmore" {
						visible = "[Not(GetVariableSystem.Exists(Concatenate('naval_battle_ship_template_group_', NavalBattleShipTemplateGroup.GetIDString)))]"
					}

					blockoverride "onclick_showless" {
						visible = "[GetVariableSystem.Exists(Concatenate('naval_battle_ship_template_group_', NavalBattleShipTemplateGroup.GetIDString))]"
					}

					blockoverride "left_text" {
						using = elide_fontsize_min

						block "local_header" {
							text = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_NAME"
						}
					}
					blockoverride "right_text" {
						section_header_right_text = {
							text = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_NUM"
						}
					}
				}

				container = {
					minimumsize = { @panel_width_half -1 }
					maximumsize = { @panel_width_half -1 }
					parentanchor = hcenter

					flowcontainer = {
						parentanchor = vcenter
						spacing = 5
						position = { 20 -5 }
						direction = vertical

						tooltipwidget = {
							FancyTooltip_ShipTemplate = {}
						}

						textbox = {
							autoresize = yes
							align = nobaseline
							text = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_TEMPLATE_NAME"
						}

						ship_type_silhouette = {
							datacontext = "[ShipTemplate.GetType]"

							blockoverride "fittype" {
								fittype = start
							}
						}
					}

					flowcontainer = {
						direction = vertical
						parentanchor = right|vcenter
						margin_right = 15
						spacing = 3

						textbox = {
							minimumsize = { 45 -1 }
							autoresize = yes
							align = right
							text = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_DESTROYED"
							tooltip = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_DESTROYED_TOOLTIP"
						}

						textbox = {
							minimumsize = { 45 -1 }
							autoresize = yes
							align = right
							text = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_WITHDRAWN"
							tooltip = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_ENTRY_WITHDRAWN_TOOLTIP"
						}
					}

					widget = { size = { 0 85 } }
				}

				dynamicgridbox = {
					visible = "[GetVariableSystem.Exists(Concatenate('naval_battle_ship_template_group_', NavalBattleShipTemplateGroup.GetIDString))]"
					parentanchor = hcenter
					datamodel_wrap = 2
					flipdirection = yes
					datamodel = "[NavalBattleShipTemplateGroup.GetShips]"

					item = {
						flowcontainer = {
							direction = vertical
							using = entry_bg_fancy
							datacontext = "[CombatShip.GetShip]"

							tooltipwidget = {
								FancyTooltip_Ship = {}
							}

							container = {
								parentanchor = top|hcenter

								widget = {
									size = { 120 25 }

									background = {
										using = dark_area
									}
								}

								textbox = {
									parentanchor = center
									autoresize = yes
									max_width = 115
									align = center
									using = elide_fontsize_min
									text = "[Ship.GetNameNoFormatting]"
								}
							}

							ship_type_silhouette = {
								datacontext = "[Ship.GetTemplate.GetType]"

								blockoverride "alpha" {
									alpha = "[TransparentIfTrue( Not( CombatShip.IsActive ))]"
								}

								blockoverride "silhouettesize" {
									size = { 130 25 }
								}

								blockoverride "fittype" {
									fittype = center
								}

								icon = {
									visible = "[CombatShip.IsSunk]"

									parentanchor = center
									size = { 25 25 }
									texture = "gfx/interface/icons/military_icons/ships_destroyed.dds"
									tooltip = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_SHIP_SUNK"
								}

								icon = {
									visible = "[CombatShip.IsWithdrawn]"

									parentanchor = center
									size = { 25 25 }
									texture = "gfx/interface/icons/military_icons/ships_fled.dds"
									tooltip = "NAVAL_BATTLE_SHIP_TEMPLATE_LIST_SHIP_WITHDRAWN"
								}
							}

							bar_horizontal_with_background = {
								parentanchor = hcenter
								size = { 90% 10 }

								blockoverride "frame_texture_density" {
									texture_density = 4
								}

								blockoverride "values" {
									min = 0
									max = 1
									value = "[CombatShip.GetHitPointPercentage]"
								}

								textbox = {
									parentanchor = center
									autoresize = yes
									align = nobaseline
									using = fontsize_xsmall

									block "first_bar_text" {
										raw_text = "#b [CombatShip.GetHitPointPercentage|0%]#!"
									}
								}

								blockoverride "color" {
									using = color_green_approval
								}
							}

							bar_horizontal_with_background = {
								parentanchor = hcenter
								size = { 90% 10 }

								blockoverride "frame_texture_density" {
									texture_density = 4
								}

								blockoverride "values" {
									min = 0
									max = 1
									value = "[CombatShip.GetCrewPercentage]"
								}

								textbox = {
									parentanchor = center
									autoresize = yes
									align = nobaseline
									using = fontsize_xsmall

									block "second_bar_text" {
										raw_text = "#b [CombatShip.GetCrewPercentage|0%]#!"
									}
								}

								blockoverride "color" {
									using = color_blue_negative
								}
							}

							widget = { size = { 8 8 } }
						}
					}
				}
			}
		}
	}

