	### NAVAL BATTLE ITEM
	type naval_battle_item = button {
		using = default_button
		size = { @panel_width 55 }
		onclick = "[InformationPanelBar.OpenNavalBattlePanelTab(NavalBattle.AccessSelf, 'default')]"
		onmousehierarchyenter = "[AccessHighlightManager.HighlightBattle(NavalBattle.Self)]"
		onmousehierarchyleave = "[AccessHighlightManager.RemoveHighlight]"
		alwaystransparent = no
		tooltip = "[NavalBattle.GetStatusString]"

		icon = {
			using = highlighted_square_selection
		
			block "highlight_visibility" {
				visible = "[NavalBattle.IsBeingHighlighted]"
			}
		}

		small_flag = {
			datacontext = "[NavalBattle.GetAttacker]"
			parentanchor = left|vcenter
			position = { 10 0 }
		}

		flowcontainer = {
			parentanchor = center
			spacing = 15

			textbox = {
				margin_left = 0
				raw_text = "@ships! [NavalBattle.GetAttackerSide.GetNumShips|v]#!"
				size = { 100 50 }
				align = right|nobaseline
				parentanchor = vcenter
				using = fontsize_large
			}

			button = {
				size = { 45 45 }
				texture = "[NavalBattle.GetBattleIcon]"
				alwaystransparent = yes
				parentanchor = vcenter
			}

			textbox = {
				margin_left = 0
				raw_text = "@ships! [NavalBattle.GetDefenderSide.GetNumShips|v]#!"
				size = { 100 50 }
				align = left|nobaseline
				parentanchor = vcenter
				using = fontsize_large
			}

		}

		small_flag = {
			datacontext = "[NavalBattle.GetDefender]"
			parentanchor = right|vcenter
			position = { -10 0 }
		}
	}

	### ENDED NAVAL BATTLE ITEM
	type ended_naval_battle_item = button {
		onclick = "[InformationPanelBar.OpenNavalBattlePanelTab(NavalBattle.AccessSelf, 'default')]"
		#onmousehierarchyenter = "[AccessHighlightManager.HighlightBattle(NavalBattle.Self)]" # TODO PRCAL-43091
		#onmousehierarchyleave = "[AccessHighlightManager.RemoveHighlight]" # TODO PRCAL-43091

		#icon = { # TODO PRCAL-43091
		#	visible = "[NavalBattle.IsBeingHighlighted]"
		#	using = highlighted_square_selection
		#}
		using = default_button

		container = {
			resizeparent = yes
			flowcontainer = {
				direction = vertical
				parentanchor = right
				margin_top = 5

				textbox = {
					text = "[NavalBattle.GetProvince.GetSeaNodeName]"
					autoresize = yes
					align = nobaseline
					parentanchor = right
					margin_right = 10
					maximumsize = { 190 -1 }
					elide = left
					fontsize_min = 12
				}
			}
			flowcontainer = {
				direction = vertical
				margin_bottom = 5
				margin_left = 5
				margin_right = 5

				background = {
					using = entry_bg_simple
				}

				# victory/defeat + captured provinces
				flowcontainer = {
					margin_left = 5
					margin_top = 5
					# if you are in the battle
					flowcontainer = {
						visible = "[NavalBattle.IsLeadCountry(AccessPlayer)]"
						direction = vertical
						spacing = 10

						textbox = {
							visible = "[NavalBattle.IsWinner(AccessPlayer)]"
							text = "BATTLE_VICTORY"
							using = small_battle_outcome_formatting
							default_format = "#p"
						}
						textbox = {
							visible = "[NavalBattle.IsLoser(AccessPlayer)]"
							text = "BATTLE_DEFEAT"
							using = small_battle_outcome_formatting
							default_format = "#n"
						}
						textbox = {
							visible = "[NavalBattle.EndedInconclusively]"
							text = "BATTLE_INCONCLUSIVE"
							using = small_battle_outcome_formatting
							default_format = "#n"
						}
					}

					# if you are observer
					flowcontainer = {
						visible = "[Not( NavalBattle.IsLeadCountry(AccessPlayer) )]"
						direction = vertical

						textbox = {
							visible = "[NavalBattle.IsOnWinnerSide( AccessPlayer )]"
							text = "NAVAL_BATTLE_ALLY_VICTORY"
							using = small_battle_outcome_formatting
							default_format = "#p"
						}
						textbox = {
							visible = "[NavalBattle.IsOnLoserSide( AccessPlayer )]"
							text = "NAVAL_BATTLE_ALLY_DEFEAT"
							using = small_battle_outcome_formatting
							default_format = "#n"
						}
						textbox = {
							visible = "[And(Not(Or( NavalBattle.IsOnWinnerSide(AccessPlayer), NavalBattle.IsOnLoserSide(AccessPlayer) )), Not(NavalBattle.EndedInconclusively))]"
							text = "NAVAL_BATTLE_NONALLY_VICTORY"
							using = small_battle_outcome_formatting
						}
						textbox = {
							visible = "[NavalBattle.EndedInconclusively]"
							text = "BATTLE_INCONCLUSIVE_OUTCOME"
							using = small_battle_outcome_formatting
						}
					}
				}

				textbox = {
					raw_text = "NAVAL_BATTLE_END_ATTACKER_OUTCOME"
					autoresize = yes
					align = nobaseline
					margin_left = 5
					margin_bottom = 2
					minimumsize = { 350 -1 }
					elide = right
					fontsize_min = 12
				}

				widget = {
					parentanchor = hcenter
					size = { @panel_width_minus_10 36 }

					background = {
						using = entry_bg_simple
					}

					icon = {
						size = { 30 30 }
						texture = "[NavalBattle.GetBattleIcon]"
						alwaystransparent = yes
						parentanchor = center
					}

					### LEFT SIDE
					flowcontainer = {
						datacontext = "[NavalBattle.GetAttackerSide]"
						position = { 10 0 }
						parentanchor = vcenter
						spacing = 10

						tiny_flag_no_interact = {
							datacontext = "[NavalBattle.GetAttacker]"
							parentanchor = vcenter
						}

						textbox = {
							raw_text = "@ships! #v [NavalBattleSide.GetNumShips] / [NavalBattleSide.GetStartingNumShips]#!"
							tooltip = "[NavalBattleSide.GetNumShipsAtStartOfBattleDesc]"
							autoresize = yes
							align = left|nobaseline
							parentanchor = vcenter
							alpha = "[TransparentIfZero_int32(NavalBattle.GetStartingAttackerShips)]"
						}

						textbox = {
							raw_text = "@ships_fled! #v [NavalBattleSide.GetNumShipsWithdrawn]#!"
							tooltip = "[NavalBattleSide.GetNumShipsAtStartOfBattleDesc]"
							autoresize = yes
							align = right|nobaseline
							parentanchor = vcenter
						}
					}

					### RIGHT SIDE
					flowcontainer = {
						datacontext = "[NavalBattle.GetDefenderSide]"
						position = { -10 0 }
						parentanchor = vcenter|right
						spacing = 10
						alpha = "[TransparentIfZero_int32(NavalBattle.GetStartingDefenderShips)]"

						textbox = {
							raw_text = "@ships_fled! #v [NavalBattleSide.GetNumShipsWithdrawn]#!"
							tooltip = "[NavalBattleSide.GetNumShipsAtStartOfBattleDesc]"
							autoresize = yes
							align = right|nobaseline
							parentanchor = vcenter
						}

						textbox = {
							raw_text = "@ships! #v [NavalBattleSide.GetNumShips] / [NavalBattleSide.GetStartingNumShips]#!"
							tooltip = "[NavalBattleSide.GetNumShipsAtStartOfBattleDesc]"
							autoresize = yes
							align = left|nobaseline
							parentanchor = vcenter
							alpha = "[TransparentIfZero_int32(NavalBattle.GetStartingAttackerShips)]"
						}

						tiny_flag_no_interact = {
							datacontext = "[NavalBattle.GetDefender]"
							parentanchor = vcenter
						}
					}
				}
			}
		}
	}

	type battle_results = flowcontainer {
		parentanchor = hcenter
		visible = "[NavalBattle.IsLeadCountry(AccessPlayer)]"
		direction = vertical
		spacing = 5

		textbox = {
			using = entry_bg_fancy
			margin = { 100 6 }
			visible = "[NavalBattle.IsWinner(AccessPlayer)]"
			align = hcenter
			text = "BATTLE_VICTORY"
			using = battle_outcome_formatting
			default_format = "#p"
		}

		textbox = {
			using = entry_bg_fancy
			margin = { 100 6 }
			visible = "[NavalBattle.IsLoser(AccessPlayer)]"
			align = hcenter
			text = "BATTLE_DEFEAT"
			using = battle_outcome_formatting
			default_format = "#n"
		}

		textbox = {
			using = entry_bg_fancy
			margin = { 100 6 }
			visible = "[NavalBattle.EndedInconclusively]"
			align = hcenter
			text = "BATTLE_INCONCLUSIVE"
			using = battle_outcome_formatting
			default_format = "#n"
		}

		textbox = {
			visible = "[NavalBattle.HasEnded]"
			text = "NAVAL_BATTLE_END_ATTACKER_OUTCOME"
			parentanchor = hcenter
			autoresize = yes
			align = hcenter
			using = fontsize_xxl
			elide = right
		}

		textbox = {
			visible = "[NavalBattle.HasEnded]"
			parentanchor = hcenter
			align = hcenter
			minimumsize = { 350 -1 }
			text = "NAVAL_BATTLE_END_DATE"
			using = elide_fontsize_min
		}
	}

	### ATTACKER SIDE - Is Actor
	type attacker_battle_log_actor = flowcontainer {
		direction = vertical
		datacontext = "[BattleLogEntry.GetActor]"

		spacing = 10
		visible = "[Not(BattleLogEntry.IsActorDefender)]"

		ship_type_silhouette = {
			datacontext = "[BattleLogEntry.GetActor.GetType]"

			block "direction" {}

			blockoverride "fittype" {
				fittype = center
			}

			tooltipwidget = {
				FancyTooltip_Ship = {
					blockoverride "icons_and_bars" {

						military_formation_icon_and_bars = {
							datacontext = "[Ship.GetFleet]"
							size = { 500 80 }

							blockoverride "first_bar_size" {
								size = { 500 25 }
							}

							blockoverride "second_bar_size" {
								size = { 500 18 }
							}

							blockoverride "third_bar_size" {
								size = { 500 18 }
							}

							blockoverride "first_bar_tooltip" {
								tooltip = "SHIP_HIT_POINTS_TOOLTIP"
							}

							blockoverride "second_bar_tooltip" {
								tooltip = "SHIP_CREW_TOOLTIP"
							}

							blockoverride "first_bar_values" {
								min = 0
								max = 1
								value = "[BattleLogEntry.GetActorCurrentHitPointPercentage]"
							}

							blockoverride "second_bar_values" {
								min = 0
								max = 1
								value = "[BattleLogEntry.GetActorCurrentCrewPercentage]"
							}

							blockoverride "first_bar_text" {
								raw_text = "@ship_hp! #b [BattleLogEntry.GetActorCurrentHitPoints|0] / [BattleLogEntry.GetActorMaxHitPoints|0]"
							}

							blockoverride "second_bar_text" {
								raw_text = "@crew! #b [BattleLogEntry.GetActorCurrentCrew|D]#! / [BattleLogEntry.GetActorMaxCrew|D]"
							}

							blockoverride "entire_icon" {}
						}
					}					
				}
			}			
		}

		flowcontainer  = {
			parentanchor = hcenter
			spacing = 5

			tiny_flag_no_interact = {
				datacontext = "[NavalBattle.GetAttacker]"
				blockoverride "is_player_glow_size" {
					size = { 270% 270% }
				}
			}

			flowcontainer = {
				direction = vertical

				bar_horizontal_with_background = {
					size = { 110 10 }

					blockoverride "values" {
						min = 0
						max = 1
						value = "[BattleLogEntry.GetActorCurrentHitPointPercentage]"
					}

					blockoverride "color" {
						using = color_green_approval
					}

					blockoverride "frame_texture_density" {
						texture_density = 3
					}

					textbox = {
						parentanchor = center
						autoresize = yes
						align = nobaseline
						using = fontsize_xsmall
						raw_text = "#b [BattleLogEntry.GetActorCurrentHitPointPercentage|0%]#!"
					}
				}

				bar_horizontal_with_background = {
					size = { 110 10 }

					blockoverride "values" {
						min = 0
						max = 1
						value = "[BattleLogEntry.GetActorCurrentCrewPercentage]"
					}

					blockoverride "color" {
						using = color_blue_negative
					}

					blockoverride "frame_texture_density" {
						texture_density = 3
					}

					textbox = {
						parentanchor = center
						autoresize = yes
						align = nobaseline
						using = fontsize_xsmall
						raw_text = "#b [BattleLogEntry.GetActorCurrentCrewPercentage|0%]#!"
					}
				}
			}						
		}
	}

