	type filter_button_battle_log = button {
		using = default_button
		using = tooltip_above

		block "size" {
			size = { 135 40 }
		}

		block "onclick" {
			onclick = "[Market.TogglePinInOutliner]"
		}

		textbox = {
			parentanchor = center
			size = { 90% 100% }
			align = hcenter|nobaseline
			using = elide_fontsize_min

			block "text" {
				text = "ALL"
			}
		}
	}

	type filter_background_selected_battle_log = widget {
		using = tooltip_above

