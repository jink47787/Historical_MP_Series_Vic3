	type ship_modifier_accuracy_mult = ship_stat {
		size = { 350 36 }

		blockoverride "stat_icon" {
			texture = "gfx/interface/icons/military_icons/navy_icons/accuracy.dds"
		}

		blockoverride "stat_tooltip" {
			tooltip = "[Modifier.GetDescFor('ship_accuracy_mult')]"
		}

		blockoverride "stat_value" {
			text = "[Modifier.GetValueFor('ship_accuracy_mult')|+=v0%]"
		}

		blockoverride "stat_label" {
			text = "[concept_accuracy]"
		}
	}

	type ship_modifier_battle_condition_accuracy_penalty = ship_stat {
		size = { 350 36 }

		blockoverride "stat_icon" {
			texture = "gfx/interface/icons/military_icons/navy_icons/accuracy.dds"
		}

		blockoverride "stat_tooltip" {
			tooltip = "[Modifier.GetDescFor('ship_battle_condition_accuracy_penalty_mult')]"
