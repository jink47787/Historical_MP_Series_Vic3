# COPY-PASTED FOR NOW
@panel_width_minus_10 = 530			# used to be 450
@panel_width = 540  				# used to be 460
@panel_width_half = 270				# used to be 230
@panel_width_plus_10 = 550  		# used to be 470
@panel_width_plus_14 = 554			# used to be 474
@panel_width_plus_14_half = 277		# used to be 237
@panel_width_plus_20 = 560			# used to be 480
@panel_width_plus_30 = 570			# used to be 490
@panel_width_plus_70 = 610			# used to be 530

ship_change_name_popup_type = {
	name = ship_change_name_popup
}

types ship_change_name
{
	type ship_change_name_popup_type = default_popup
	{
		datacontext = "[ShipChangeNamePopup.GetShip]"

		blockoverride "window_header_name"
		{
			text = "CHANGE_NAME"
		}

		blockoverride "header_close_button_visibility"
		{
			visible = yes
		}

		blockoverride "header_close_button"
		{
			visible = yes
			onclick = "[PopupManager.HideShipChangeName]"
		}

		blockoverride "entire_scrollarea"
		{
			flowcontainer = {
				direction = vertical

				#background = {
				#	using = default_background
				#}

				# "Choose Name" section
				flowcontainer = {
					direction = vertical
					spacing = 10

					# Set a custom name
					editbox = {
						visible = yes
						background = {
							using = text_edit_bg
						}

						# The name is referenced in code. If you change it, it will no longer get properly reset
						name = "ship_name_edit"
						ontextedited = "[ShipChangeNamePopup.OnEditName]"
						maxcharacters = 50
						size = { 420 40 }
						margin_left = 10
						alwaystransparent = no
						focuspolicy = all
						focus_on_visible = yes
						align = left|nobaseline
					}

					flowcontainer = {
						direction = horizontal
						using = default_list_position
						spacing = 20

						button = {
							using = default_button
							using = close_button_sound
							size = { 140 40 }
							text = "CANCEL"
							shortcut = "close_window"
							onclick = "[PopupManager.HideShipChangeName]"
						}
						button = {
							using = default_button_primary_action
							using = confirm_button_sound
							name = "confirmation_button"
							size = { 140 40 }
							text = "CONFIRM"
							enabled = "[IsValid(ShipChangeNamePopup.Confirm)]"
							onclick = "[Execute(ShipChangeNamePopup.Confirm)]"
							tooltip = "[GetDesc(ShipChangeNamePopup.Confirm)]"
							onclick = "[PopupManager.HideShipChangeName]"
						}
					}

					widget = {
						size = { 420 10 }
					}
				}


			}
		}

		blockoverride "bottom_margin"
		{
			margin_bottom = 50
		}
	}
}

types ship_viewer_types
{
	type ship_viewer = icon {
		name = "ship_viewer_widget"
		size = { 100% 370 }
		gfxtype = jomini_entitygfx_sprite
		entity_instance = "[ShipViewer.GetEntity]"
		#using = frame_small_mask

		shaderfile = "gfx/FX/pdxgui_default.shader"
		effectname = "PdxGuiDefault"
		render_pass = "[GetGuiEntityShaderRenderpass]"

		gfx_environment_file = "gfx/map/environment/ui_ship_viewer_environment.txt"
		enabled_post_effects = luminance

		camera_position = "[ShipViewer.GetCameraPosition]"
		camera_look_at = "[ShipViewer.GetCameraLookAt]"
		camera_fov_y_degrees = 12
		camera_near_far = { 0.1 300.0 }
		alwaystransparent = no
	}
}

types ship_panel_types
{
	type ship_panel = default_block_window_two_lines {
		name = "ship_panel"
		datacontext = "[ShipPanel.GetShip]"

		blockoverride "animation_state_block" {
			state = {
				name = _show
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/military"
				}
			}

			state = {
				name = _hide
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/military_stop"
				}
			}
		}

		blockoverride "window_header_name"
		{
			text = "SHIP_PANEL_NAME"
		}

		blockoverride "window_header_name_line_two"
		{
			text = "SHIP_SUBTITLE"
		}

		blockoverride "goto_visibility" {}

		blockoverride "goto_properties" {
			onclick = "[Ship.ZoomTo]"
			tooltip = "ZOOM_TO_SHIP"
			enabled = "[Not( Ship.IsZoomingTo )]"
		}

		blockoverride "edit_visibility" {
			visible = "[Ship.GetCountry.IsLocalPlayer]"
		}

		blockoverride "edit_tooltip" {
			tooltip = "CHANGE_NAME"
		}

		blockoverride "edit_properties" {
			onclick = "[PopupManager.ShowShipChangeName(Ship.Self)]"
			#enabled = yes
		}

		blockoverride "goto_button" {
			button_icon_goto = {
				size = { 30 30 }
				datacontext = "[Ship.GetFleet]"
				tooltip = "GO_TO_BUTTON_MILITARY_FORMATION"
				onclick = "[InformationPanelBar.OpenMilitaryFormationPanelTab( MilitaryFormation.Self, 'default' )]"
				input_action = "go_to_details"
			}
		}

		blockoverride "fixed_bottom" {
			flowcontainer = {
				minimumsize = { @panel_width_plus_14 -1 }
				direction = vertical
				spacing = 5
				using = default_fade_in_out

				divider_clean = {
					size = { @panel_width_plus_14 4 }
				}

				background = {
					using = dark_area
				}

				widget = {
					size = { 5 2 }
				}

				flowcontainer = {
					parentanchor = hcenter
					spacing = 5

					### Flagship info
					flowcontainer = {
						direction = vertical
						visible = "[HasDlcFeature('ship_designer')]"

						button = {
							visible = "[And(Not(Ship.IsFlagship), Ship.GetCountry.IsLocalPlayer)]"
							using = default_button_action
							size = { 180 40 }
							onclick = "[PopupManager.AskConfirmation(Ship.AssignAsFlagship)]"
							enabled = "[IsValid(Ship.AssignAsFlagship)]"

							text = "ASSIGN_AS_FLAGSHIP_BUTTON"
							tooltip = "ASSIGN_AS_FLAGSHIP_BUTTON_TOOLTIP"
							using = tooltip_ne
						}

						button = {
							visible = "[And(Ship.IsFlagship, Ship.GetCountry.IsLocalPlayer)]"
							using = default_button_action
							size = { 180 40 }
							onclick = "[PopupManager.AskConfirmation(Ship.UnassignAsFlagship)]"
							enabled = "[IsValid(Ship.UnassignAsFlagship)]"

							text = "UNASSIGN_AS_FLAGSHIP_BUTTON"
							tooltip = "UNASSIGN_AS_FLAGSHIP_BUTTON_TOOLTIP"
							using = tooltip_ne

							icon = {
								using = highlighted_active_square_selection
							}
						}
					}

					### RETROFIT
					flowcontainer = {
						direction = vertical

						### START RETROFIT
						button = {
							visible = "[Not(Ship.IsToRetrofit)]"
							using = default_button
							size = { 180 40 }
							using = action_send_ship_to_retrofit
							enabled = "[IsValid(Ship.Retrofit)]"
							onclick = "[Execute(Ship.Retrofit)]"

							text = "RETROFIT_SHIP_BUTTON"
							tooltip = "RETROFIT_SHIP_BUTTON_TOOLTIP"
							using = tooltip_ne
						}

						### CANCEL RETROFIT
						button = {
							visible = "[Ship.IsToRetrofit]"
							using = default_button_action
							size = { 180 40 }
							using = fleet_panel_construction_template_build_cancel
							enabled = "[IsValid(Ship.CancelRetrofit)]"
							onclick = "[Execute(Ship.CancelRetrofit)]"

							text = "CANCEL_RETROFIT_SHIPS_BUTTON"
							tooltip = "RETROFIT_SHIP_CANCEL_BUTTON_TOOLTIP"
							using = tooltip_ne
						}
					}

					flowcontainer = {
						direction = vertical

						### Change Template
						button = {
							using = default_button
							size = { 180 40 }
							onclick = "[RightClickMenuManager.ToggleShipChangeTemplateActions(Ship.AccessSelf, PdxGuiWidget.AccessSelf)]"

							text = "CHANGE_TEMPLATE"
							tooltip = "BUTTON_CHANGE_TEMPLATE_SINGLE_SHIP_TOOLTIP"
							using = tooltip_ne
						}
					}
				}

				widget = {
					size = { 5 2 }
				}
			}
		}

		blockoverride "bottom_spacing" {}

		blockoverride "scrollarea_content"
		{
			flowcontainer = {
				direction = vertical
				minimumsize = { @panel_width_plus_14 -1 }
				maximumsize = { @panel_width_plus_14 -1 }
				datacontext = "[Ship.GetFleet]"

				widget = {
					parentanchor = hcenter
					size = { @panel_width_plus_14 370 }

					### 3D Ship View
					ship_viewer = {
						datacontext = "[ShipPanel.GetShipViewer]"

						console_button = {
							visible = "[InDebugMode]"
							parentanchor = left
							position = { 10 70 }
							raw_text = "Entity States"
							onclick = "[ExecuteConsoleCommand('gui.CreateDockable gui/debug_menues.gui ship_viewer_entity_states_from_ship_panel')]"
						}
					}

					icon = {
						parentanchor = top
						position = { 8 0 }
						size = { 55	55 }
						alpha = 0.8
						texture = "gfx/interface/icons/generic_icons/rotate_zoom.dds"
					}

					### Reset Camera Button
					button_icon_round_action = {
						size = { 34 34 }
						parentanchor = top
						position = { 70 10 }
						tooltip = "RESET_CAMERA"
						onclick = "[ShipPanel.GetShipViewer.ResetCamera]"

						blockoverride "icon_size" {
							size = { 75% 75% }
						}

						blockoverride "icon" {
							texture = "gfx/interface/buttons/button_icons/reset_camera.dds"
						}
					}

					### DELETE FORMATION
					button_icon_round_action = {
						size = { 34 34 }
						parentanchor = right
						position = { -10 10 }
						tooltip = "DECOMMISSION_SHIP_TOOLTIP"
						enabled = "[IsValid( Ship.Decommission )]"
						onclick = "[PopupManager.AskConfirmationCustomWithSound(Ship.Decommission, 'ship_decommission_confirmation_window', 'event:/SFX/UI/FleetPanel/fleetpanel_ship_decommission')]"

						blockoverride "icon_size" {
							size = { 65% 65% }
						}

						blockoverride "icon" {
							texture = "gfx/interface/icons/military_icons/disband_formation.dds"
						}
					}

					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/navy/navy_bg_frame.dds"
						spriteType = Corneredtiled

						spriteborder_left = 200
						spriteborder_right = 60
						spriteborder_top = 170
						spriteborder_bottom = 180

						texture_density = 2
					}

					### Flagship Ornament Selector
					flowcontainer = {
						parentanchor = bottom|hcenter
						position = { 0 -10 }
						visible = "[And(Ship.IsFlagship, HasDlcFeature('ship_designer'))]"
						spacing = 5

						button_select_arrow = {
							parentanchor = vcenter
							mirror = horizontal
							size = { 33 33 }
							using = confirm_button_sound
							enabled = "[IsValid( Ship.SetPrevFlagshipOrnament )]"
							onclick = "[Execute( Ship.SetPrevFlagshipOrnament )]"
							tooltip = "FLAGSHIP_ORNAMENT_PREV_TOOLTIP"
							using = tooltip_se
						}

						textbox = {
							background = {
								using = dark_area
								alpha = 0.4
							}

							margin = { 0 3 }
							parentanchor = vcenter
							autoresize = yes
							align = hcenter|nobaseline
							min_width = 150
							max_width = 220
							default_format = "#title"
							text = "[Ship.GetFlagshipOrnamentName]"
						}

						button_select_arrow = {
							parentanchor = vcenter
							size = { 33 33 }
							using = confirm_button_sound
							enabled = "[IsValid( Ship.SetNextFlagshipOrnament )]"
							onclick = "[Execute( Ship.SetNextFlagshipOrnament )]"
							tooltip = "FLAGSHIP_ORNAMENT_NEXT_TOOLTIP"
							using = tooltip_se
						}
					}

					state = {
						name = _show
						using = viewport_sound_parameter_open
						using = ship_panel_open
					}

					state = {
						name = _hide
						using = viewport_sound_parameter_close
					}

				}

				naval_battle_item = {
					visible = "[Ship.IsInBattle]"
					datacontext = "[Ship.GetNavalBattle]"
					parentanchor = hcenter
				}

				default_header = {
					using = default_list_position

					blockoverride "text" {
						text = "SHIP_DETAILS_HEADER"
					}
				}

				widget = {
					size = { 5 5 }
				}

				#SHIP NAME AND SILHOUETTE
				flowcontainer = {
					parentanchor = hcenter
					spacing = 20
					margin = { 20 10 }

					background = {
						using = entry_bg_simple
					}

					flowcontainer = {
						parentanchor = vcenter
						direction = vertical

						textbox = {
							autoresize = yes
							align = nobaseline
							using = fontsize_small
							text = "[Ship.GetType.GetName]"
						}

						textbox = {
							autoresize = yes
							align = nobaseline
							text = "[Ship.GetTemplate.GetName]"
						}

						widget = {
							size = { 10 5 }
						}

						ship_type_silhouette = {
							datacontext = "[Ship.GetType]"

							blockoverride "fittype" {
								fittype = start
							}
						}
					}

					flowcontainer = {
						parentanchor = vcenter
						direction = vertical
						spacing = 10

						military_formation_icon_and_bars = {
							datacontext = "[Ship.GetFleet]"
							size = { 300 80 }

							blockoverride "first_bar_size" {
								size = { 300 25 }
							}

							blockoverride "second_bar_size" {
								size = { 300 18 }
							}

							blockoverride "third_bar_size" {
								size = { 300 18 }
							}

							blockoverride "first_bar_tooltip" {
								tooltip = "SHIP_HIT_POINTS_TOOLTIP"
							}

							blockoverride "second_bar_tooltip" {
								tooltip = "SHIP_CREW_TOOLTIP"
							}

							blockoverride "first_bar_values" {
								min = 0
								max = 1
								value = "[FixedPointToFloat(Ship.GetHitPointsPercentage)]"
							}

							blockoverride "second_bar_values" {
								min = 0
								max = "[Ship.GetCrewMax]"
								value = "[Ship.GetTotalCrew]"
							}

							blockoverride "first_bar_text" {
								raw_text = "@ship_hp! #b [Ship.GetHitPoints|0]#!/[Ship.GetHitPointsMax|0]" #todo
							}

							blockoverride "second_bar_text" {
								raw_text = "@crew! #b [Ship.GetTotalCrew|D]#! / [Ship.GetCrewMax|D]"
							}

							blockoverride "entire_icon" {}
						}
					}
				}

				widget = {
					size = { 5 5 }
				}


				# KEY STATS
				flowcontainer = {
					margin = { 30 5 }
					spacing = 20
					parentanchor = hcenter

					flowcontainer = {
						parentanchor = vcenter
						spacing = 5

						### SHIP UPKEEP
						small_header_grid_item = {
							tooltip = "SHIP_UPKEEP_TOOLTIP"

							blockoverride "text" {
								text = "[Ship.GetUpkeepCost|0-K]"
							}

							blockoverride "icon" {
								texture = "gfx/interface/icons/topbar/income_power_icon.dds"
							}
						}

						### ARMOR
						small_header_grid_item = {
							tooltip = "SHIP_ARMOR_TOOLTIP"

							blockoverride "text" {
								raw_text = "#v [Ship.GetArmor|0]#!"
							}

							blockoverride "icon" {
								texture = "gfx/interface/icons/military_icons/navy_icons/armor_navy.dds"
							}
						}

						### AVERAGE ATTACK DAMAGE
						small_header_grid_item = {
							datacontext = "[Ship.GetModifier]"
							tooltip = "SHIP_TEMPLATE_ATTACK_DAMAGE_TOOLTIP"

							blockoverride "text" {
								raw_text = "#v [Ship.GetAverageAttackDamage|0]#!"
							}

							blockoverride "icon" {
								texture = "gfx/interface/icons/military_icons/navy_icons/average_damage_navy.dds"
							}
						}

						### SPEED
						small_header_grid_item = {
							tooltip = "SHIP_SPEED_TOOLTIP"

							blockoverride "text" {
								text = "[Ship.GetMovementSpeed|v^2]"
							}

							blockoverride "icon" {
								texture = "gfx/interface/icons/military_icons/navy_icons/speed_navy.dds"
							}
						}

						### SUPPLY CAPACITY
						small_header_grid_item = {
							datacontext = "[Ship.GetModifier]"
							tooltip = "[Modifier.GetShipSupplyCapacityTooltip]"

							blockoverride "text" {
								text = "[Modifier.GetShipSupplyCapacity|v0]"
							}

							blockoverride "icon" {
								texture = "gfx/interface/icons/military_icons/navy_icons/supplies_navy.dds"
							}
						}
					}
				}

				divider_clean = {}

				flowcontainer = {
					parentanchor = hcenter

					flowcontainer = {
						direction = vertical

						### Crit Chance
						ship_stat_critical_hit_chance = {}

						### Crit Damage
						ship_stat_critical_hit_multiplier = {}

						### Vulnerability
						ship_stat_vulnerability = {}

						### Screening
						ship_stat_screening = {}

						### Accuracy
						ship_stat_accuracy = {}
					}

					vertical_divider_full = {}

					flowcontainer = {
						direction = vertical

						### Supply Efficiency
						ship_stat_supply_efficiency = {}

						### Visibility
						ship_stat_visibility = {}

						### Detection/Stealth
						ship_stat_detection = {}

						### Blockade Strength
						ship_stat_blockade_strength = {}

						### Readiness Gain
						ship_stat_readiness_gain = {}
					}
				}

				widget = {
					size = { 5 5 }
				}

				default_header = {
					using = default_list_position

					blockoverride "text" {
						text = "SHIP_CREW_ORIGIN_STATES_HEADER"
					}
				}

				### States and Buildings - Crew
				flowcontainer = {
					parentanchor = hcenter
					direction = vertical

					flowcontainer = {
						parentanchor = hcenter

						sort_button = {
							size = { 360 30 }
							text = "SHIP_BUILDING_AND_STATES_SORT_BUTTON_TEXT"
							align = nobaseline
							onclick = "[Ship.SortCrewOriginStates('state_name')]"
						}

						sort_button = {
							size = { 90 30 }
							tooltip = "[concept_building_level]"
							text = "concept_building_levels_short"
							align = hcenter|nobaseline
							onclick = "[Ship.SortCrewOriginStates('building_level')]"
						}

						sort_button = {
							size = { 90 30 }
							tooltip = "SHIP_CREW_FROM_STATE_SORT_BUTTON_TOOLTIP"
							text = "SHIP_CREW_FROM_STATE_SORT_BUTTON"
							align = hcenter|nobaseline
							onclick = "[Ship.SortCrewOriginStates('num_crew')]"
						}
					}

					flowcontainer = {
						visible = "[Not(IsDataModelEmpty(Ship.GetCrewOriginStates))]"
						parentanchor = hcenter
						direction = vertical
						datamodel = "[Ship.GetCrewOriginStates]"

						item = {
							flowcontainer = {
								direction = vertical

								widget = {
									visible = "[State.HasBuilding('building_naval_administration')]"
									size = { 540 40 }
									datacontext = "[State.AccessBuilding('building_naval_administration')]"

									background = {
										using = fade_right_entry_header_colored
										color = "[State.GetOwner.GetMapColor]"
									}

									flowcontainer = {
										parentanchor = vcenter
										spacing = 5
										margin_left = 5

										icon = {
											parentanchor = vcenter
											size = { 30 30 }
											texture = "[Building.GetIcon]"
										}

										textbox = {
											parentanchor = vcenter
											autoresize = yes
											max_width = 280
											align = nobaseline
											using = elide_fontsize_min
											text = "SHIP_CREW_BUILDING_AND_STATE_NAME"
										}

										button_icon_goto = {
											parentanchor = vcenter
											size = { 25 25 }
											tooltip = "GO_TO_BUTTON_BUILDING"
											onclick = "[InformationPanelBar.OpenBuildingDetailsPanel(Building.AccessSelf)]"
										}
									}

									flowcontainer = {
										parentanchor = vcenter|right
										datacontext = "[State.AccessBuilding('building_naval_administration')]"

										textbox = {
											parentanchor = vcenter
											size = { 90 30 }
											align = hcenter|nobaseline
											using = elide_fontsize_min
											text = "BUILDING_SIZE"

											tooltipwidget = {
												FancyTooltip_Building = {}
											}
										}

										textbox = {
											parentanchor = vcenter
											size = { 90 30 }
											tooltip = "SHIP_CREW_STATE_TOOLTIP"
											align = hcenter|nobaseline
											default_format = "#v"
											margin_right = 15
											using = elide_fontsize_min
											raw_text = "@crew! #v [Ship.GetNumCrewFromState(State.Self)|D]#!"
										}
									}

									divider_clean = {
										parentanchor = bottom|hcenter
										size = { 100% 1 }
									}

								}

								widget = {
									visible = "[Not(State.HasBuilding('building_naval_administration'))]"
									size = { 540 40 }

									background = {
										using = fade_right_entry_header_colored
										color = "[State.GetOwner.GetMapColor]"
									}

									flowcontainer = {
										parentanchor = vcenter
										spacing = 5
										margin_left = 5

										textbox = {
											parentanchor = vcenter
											autoresize = yes
											max_width = 280
											align = nobaseline
											using = elide_fontsize_min
											text = "SHIP_CREW_STATE_NAME"
										}

										button_icon_goto = {
											parentanchor = vcenter
											size = { 25 25 }
											tooltip = "GO_TO_BUTTON_STATE"
											onclick = "[InformationPanelBar.OpenStatePanel(State.AccessSelf)]"
										}
									}

									flowcontainer = {
										parentanchor = vcenter|right

										textbox = {
											parentanchor = vcenter
											size = { 90 30 }
											align = hcenter|nobaseline
											using = elide_fontsize_min
											text = "DASH_WITH_SPACING"
										}

										textbox = {
											parentanchor = vcenter
											size = { 90 30 }
											tooltip = "SHIP_CREW_STATE_TOOLTIP"
											align = hcenter|nobaseline
											default_format = "#v"
											margin_right = 15
											using = elide_fontsize_min
											raw_text = "@crew! #v [Ship.GetNumCrewFromState(State.Self)|D]#!"
										}
									}

									divider_clean = {
										parentanchor = bottom|hcenter
										size = { 100% 1 }
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

types ship_types
{
	type ship_stat = widget {
		parentanchor = left
		size = { 270 36 }

		hbox = {
			layoutpolicy_horizontal = expanding
			margin = { 10 5 }
			spacing = 5

			icon = {
				size = { 24 24 }

				block "stat_icon" {
					texture = "gfx/interface/icons/harvest_condition_icons/placeholder.dds"
				}
			}

			textbox = {
				size = { 46 30 }
				align = nobaseline
				using = elide_fontsize_min

				block "stat_tooltip" {
				}

				block "stat_value" {
				}
			}

			textbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				align = nobaseline
				using = elide_fontsize_min

				block "stat_label" {
					text = "[concept_ship_speed]"
				}
			}
		}

		divider_clean = {
			parentanchor = bottom
		}
	}

	## Base Stat types
	type ship_stat_base_armor = ship_stat {
		blockoverride "stat_icon" {
			texture = "gfx/interface/icons/military_icons/navy_icons/armor_navy.dds"
		}

		blockoverride "stat_label" {
			text = "[concept_ship_armor]"
